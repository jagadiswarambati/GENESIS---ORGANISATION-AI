# Application
GENESIS_ENVIRONMENT=development
# AI provider: mock (default), openai, or gemini.
GENESIS_AI_PROVIDER=mock
# Required only when GENESIS_AI_PROVIDER=openai.
OPENAI_API_KEY=
# OpenAI Responses API model used by the Architect and OpenAI execution provider.
GENESIS_OPENAI_MODEL=gpt-5.6
# Required only when GENESIS_AI_PROVIDER=gemini.
GEMINI_API_KEY=
# Gemini model used by Gemini-backed Architect and execution calls.
GENESIS_GEMINI_MODEL=gemini-2.5-flash
GENESIS_FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# PostgreSQL
POSTGRES_DB=genesis
POSTGRES_USER=genesis
POSTGRES_PASSWORD=genesis
GENESIS_DATABASE_URL=postgresql+asyncpg://genesis:genesis@localhost:5432/genesis

# Redis
GENESIS_REDIS_URL=redis://localhost:6379/0
